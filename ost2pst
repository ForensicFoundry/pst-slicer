#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
"""ost2pst - convert an Outlook OST file to a portable mailbox format.

This is a **completely stand-alone Python 3 script**. It has NO
dependency on ``pst_slicer`` and uses only the Python standard
library. Drop it into any tools directory and it works.

What it actually does (and why the name is aspirational on Linux)
-----------------------------------------------------------------
There is no free, open-source Linux tool that writes native
Microsoft PST format. ``libpff``, ``libpst``, and every other
open-source Personal Folder File library ships read-only support.
The only tools that can produce a real ``.pst`` file are
proprietary and Windows-only (Outlook itself, Stellar OST-to-PST,
Kernel for OST, SysTools, etc.).

For the vast majority of downstream forensic and e-discovery workflows, MBOX or
per-message EML is a **better** intermediate than PST anyway:

* MBOX and EML are RFC-standardized plain text; PST is a proprietary
  compound-storage container whose spec is only partially published.
* MBOX and EML are trivially indexable by e-discovery platforms,
  every mail client, every ``grep``.
* MBOX and EML round-trip through ``pst-slicer`` and every other
  forensic mail tool without loss.

So on Linux this tool converts OST -> MBOX (default) or OST -> per-
message EML tree, using ``readpst`` from the ``libpst-utils`` package
as the actual mailbox reader. It wraps ``readpst`` with:

* A file-signature check that refuses to run on anything that is not
  a Personal Folder File (OST or PST).
* SHA-256 chain-of-custody hashing of the input file BEFORE and AFTER
  the conversion, so we can prove the tool did not mutate the
  evidence. (``readpst`` opens the OST read-only; this check is
  belt-and-suspenders.)
* SHA-256 + size fingerprints for every output artifact, written to
  ``MANIFEST.tsv`` next to the outputs.
* A ``CONVERSION.txt`` provenance record (invocation, tool version,
  ``readpst`` version, UTC timestamps, hostname, user, exit code).

If you truly need a native ``.pst`` file (e.g. because the receiving
party's tooling demands it), pass the produced MBOX/EML tree to a
Windows-based OST-to-PST converter or import it into Outlook via
``File -> Open & Export`` on Windows.

Usage
-----
    ost2pst [-h] [-v] [--format {mbox,eml}] [--include-deleted]
            [--force] INPUT OUTPUT_DIR

Exit codes
----------
    0    Conversion succeeded and manifest written.
    1    Conversion attempt failed (readpst returned non-zero).
    2    Setup problem (bad path, wrong signature, readpst not
         installed, unwritable output dir, ...).
    130  Interrupted by user (Ctrl-C).
"""

from __future__ import annotations

import argparse
import datetime as _dt
import getpass
import hashlib
import os
import platform
import re
import shutil
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import IO, Any


PROG = "ost2pst"
VERSION = "26.07"
TAGLINE = "Convert Outlook OST to a portable mailbox format"
_CHUNK = 1024 * 1024  # 1 MiB


# ---------------------------------------------------------------------------
# Palette (self-contained; mirrors pst_slicer.palette but has no imports)
# ---------------------------------------------------------------------------


class _Palette:
    __slots__ = (
        "BOLD",
        "DIM",
        "RESET",
        "RED",
        "GREEN",
        "YELLOW",
        "BLUE",
        "MAGENTA",
        "CYAN",
    )

    def __init__(self, enabled: bool) -> None:
        if enabled:
            self.BOLD = "\033[1m"
            self.DIM = "\033[2m"
            self.RESET = "\033[0m"
            self.RED = "\033[31m"
            self.GREEN = "\033[32m"
            self.YELLOW = "\033[33m"
            self.BLUE = "\033[34m"
            self.MAGENTA = "\033[35m"
            self.CYAN = "\033[36m"
        else:
            self.BOLD = self.DIM = self.RESET = ""
            self.RED = self.GREEN = self.YELLOW = ""
            self.BLUE = self.MAGENTA = self.CYAN = ""


def _color_enabled_for(stream: IO[Any]) -> bool:
    """Match pst-slicer's precedence:
        NO_COLOR / OST2PST_NO_COLOR   -> disable regardless of TTY
        FORCE_COLOR / OST2PST_FORCE_COLOR -> enable regardless of TTY
        otherwise: only if the stream is a TTY.
    """
    env = os.environ
    if env.get("OST2PST_NO_COLOR") or env.get("NO_COLOR"):
        return False
    if env.get("OST2PST_FORCE_COLOR") or env.get("FORCE_COLOR"):
        return True
    isatty = getattr(stream, "isatty", None)
    return bool(isatty()) if callable(isatty) else False


def _palette_for(stream: IO[Any]) -> _Palette:
    return _Palette(_color_enabled_for(stream))


# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------


def _note(msg: str) -> None:
    p = _palette_for(sys.stdout)
    sys.stdout.write(f"{p.BLUE}==>{p.RESET} {msg}\n")
    sys.stdout.flush()


def _ok(msg: str) -> None:
    p = _palette_for(sys.stdout)
    sys.stdout.write(f"  {p.GREEN}OK:{p.RESET} {msg}\n")
    sys.stdout.flush()


def _warn(msg: str) -> None:
    p = _palette_for(sys.stderr)
    sys.stderr.write(f"  {p.YELLOW}WARN:{p.RESET} {msg}\n")
    sys.stderr.flush()


def _err(msg: str) -> None:
    p = _palette_for(sys.stderr)
    sys.stderr.write(f"  {p.RED}ERROR:{p.RESET} {msg}\n")
    sys.stderr.flush()


def _header(text: str) -> None:
    p = _palette_for(sys.stdout)
    sys.stdout.write(f"\n  {p.BOLD}{text}{p.RESET}\n")
    sys.stdout.write("  " + ("-" * 40) + "\n")
    sys.stdout.flush()


def _kv(key: str, value: str) -> None:
    p = _palette_for(sys.stdout)
    sys.stdout.write(f"    {p.DIM}{key:<28}{p.RESET} {value}\n")
    sys.stdout.flush()


# ---------------------------------------------------------------------------
# argparse machinery with colorized -h/-v
# ---------------------------------------------------------------------------


def _strip_ansi(text: str) -> str:
    return re.sub(r"\x1b\[[0-9;]*m", "", text)


def _help_row(stream: IO[Any], label_colored: str, description: str) -> None:
    visible = _strip_ansi(label_colored)
    padding = max(2, 22 - len(visible))
    stream.write(f"  {label_colored}{' ' * padding}{description}\n")


def _print_version(stream: IO[Any]) -> None:
    p = _palette_for(stream)
    stream.write(
        f"{p.BOLD}{p.BLUE}{PROG}{p.RESET} {p.GREEN}v{VERSION}{p.RESET}\n"
        f"  {p.DIM}{TAGLINE} - GPL-3.0-or-later{p.RESET}\n"
    )
    stream.flush()


def _print_usage(stream: IO[Any]) -> None:
    p = _palette_for(stream)
    stream.write(
        f"{p.BOLD}Usage:{p.RESET} "
        f"{p.BLUE}{PROG}{p.RESET} "
        f"[{p.GREEN}-h{p.RESET}] "
        f"[{p.GREEN}-v{p.RESET}] "
        f"[{p.GREEN}--format {p.YELLOW}mbox|eml{p.RESET}] "
        f"[{p.GREEN}--include-deleted{p.RESET}] "
        f"[{p.GREEN}--force{p.RESET}] "
        f"{p.YELLOW}INPUT{p.RESET} {p.YELLOW}OUTPUT_DIR{p.RESET}\n"
    )
    stream.flush()


